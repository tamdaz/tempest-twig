{
    "name": "tamdaz/tempest-twig",
    "description": "A third-party package that provides Twig for Tempest.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Tamdaz\\TempestTwig\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Zohir Tamda",
            "email": "tamda.zohir.pro@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "tempest/framework": "^3.3",
        "twig/twig": "^3.23"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "carthage-software/mago": "^1.16.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tamdaz\\TempestTwig\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --display-warnings --display-skipped --display-deprecations --display-errors --display-notices",
        "lint": [
            "@php vendor/bin/mago lint",
            "@php vendor/bin/mago analyze"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
